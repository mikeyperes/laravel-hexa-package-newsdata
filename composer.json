{
    "name": "hexawebsystems/laravel-hexa-package-newsdata",
    "description": "NewsData.io — news API integration for article search, headline fetching, and content sourcing.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2"
    },
    "autoload": {
        "psr-4": {
            "hexa_package_newsdata\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "hexa_package_newsdata\\Providers\\NewsDataServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
